{
  "name": "meal-planner",
  "private": true,
  "scripts": {
    "dev": "npx nuxt dev",
    "build": "npx nuxt build",
    "preview": "npx nuxt preview",
    "postinstall": "npx nuxt prepare",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "setup": "npm install && npm run db:generate && npm run db:push && npm run db:seed",
    "prod:setup": "npm install && npm run db:generate && npm run db:push && npm run db:seed && npm run build",
    "prod:start": "node --env-file=.env .output/server/index.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "nuxt": "^3.10.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.11.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "prisma": "^5.10.0"
  }
}
