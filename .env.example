# Скопируйте в .env и заполните:
#   Windows: copy .env.example .env
#   Linux:   cp .env.example .env

# ── База данных ───────────────────────────────────────────────────────────────
# ВАЖНО: используйте абсолютный путь чтобы избежать ошибок
# Windows пример:
#   DATABASE_URL="file:D:/Dev/Projects/meal-planner/prisma/prod.db"
# Linux пример:
#   DATABASE_URL="file:/opt/meal-planner/prisma/prod.db"
DATABASE_URL="file:D:/Dev/Projects/vibe-codding/meal-planner/prisma/prod.db"

# ── Сервер ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Безопасность ─────────────────────────────────────────────────────────────
# Сгенерировать: openssl rand -hex 32
JWT_SECRET="ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ"

# ── Окружение ─────────────────────────────────────────────────────────────────
NODE_ENV=production
