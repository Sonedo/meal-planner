# Скопируйте в .env:
#   cp .env.example .env

# ── База данных ───────────────────────────────────────────────────────────────
# Абсолютный путь к SQLite файлу
DATABASE_URL="file:~/meal-planner/prod.db"

# ── Сервер ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Безопасность ─────────────────────────────────────────────────────────────
# Сгенерировать: openssl rand -hex 32
JWT_SECRET="ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ"

# ── Окружение ─────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Префикс пути (для nginx-маршрутизации) ───────────────────────────────────
# Оставьте пустым для dev или если работаете на корневом пути /
APP_BASE_URL=
